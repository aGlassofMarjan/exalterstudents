---
import type { MetricsContent } from '../lib/content-loader';

interface Props {
  metrics: MetricsContent;
}

const { metrics } = Astro.props;
---

<section class="py-20" style="background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Title + description -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{metrics.title}</h2>
      <p class="text-blue-100 text-lg max-w-2xl mx-auto">{metrics.description}</p>
    </div>

    <!-- Metrics grid: 3 cols -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      {metrics.metrics.map((item) => (
        <div class="text-center">
          <div class="text-5xl font-bold text-amber-400 mb-2">{item.value}</div>
          <div class="text-blue-100 text-base">{item.label}</div>
        </div>
      ))}
    </div>

    <!-- Achievement cards: 2 cols -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {metrics.achievementCards.map((card, i) => {
        const imgs = [
          '/images/achievement-400x524.png',
          '/images/achievement-2-400x581.png',
        ];
        return (
          <div class="bg-white rounded-xl shadow-lg border border-blue-100 overflow-hidden flex flex-col">
            <img
              src={imgs[i] ?? imgs[0]}
              alt={card.title}
              class="w-full h-48 object-cover"
            />
            <div class="p-6">
              <h3 class="text-lg font-semibold text-slate-800 mb-2">{card.title}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">{card.description}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
