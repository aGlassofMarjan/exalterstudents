---
import type { EventCard } from '../lib/content-loader';

interface Props {
  events: EventCard[];
}

const { events } = Astro.props;
---

<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row items-center gap-8 mb-12">
      <img
        src="/images/event-1-295x319.png"
        alt="Exalter Students events"
        width="295"
        height="319"
        class="rounded-2xl shadow-md object-cover w-48 md:w-56 flex-shrink-0"
      />
      <div>
        <h2 class="text-3xl font-bold text-[#1E3A8A] mb-3">Acara &amp; Kegiatan</h2>
        <p class="text-slate-600">Ikuti berbagai acara dan kegiatan inspiratif dari Exalter Students.</p>
      </div>
    </div>

    <!-- Events Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {events.map((event) => (
        <div class="bg-white rounded-lg border border-slate-200 p-6 flex flex-col hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-[#0F172A] mb-2">{event.name}</h3>
          <p class="text-slate-500 text-sm mb-4">{event.date}</p>
          <a
            href={event.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#3B82F6] hover:underline text-sm mt-auto w-fit"
          >
            Lihat Detail →
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
