---
import content from '../lib/content-loader';
import Navigation from '../components/Navigation';
import ServiceFullSection from '../components/ServiceFullSection.astro';
import MetricsSection from '../components/MetricsSection.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop';
import '../styles/global.css';
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>Program — Exalter Students | Inkubasi, Mentorship & Kompetisi</title>
    <meta name="description" content="Jelajahi program Exalter Students: Inkubasi, Mentorship, Kompetisi nasional & internasional, Konferensi, Summit, dan Komunitas untuk generasi inovatif Indonesia." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.exalterstudents.com/program" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.exalterstudents.com/program" />
    <meta property="og:title" content="Program — Exalter Students | Inkubasi, Mentorship & Kompetisi" />
    <meta property="og:description" content="Jelajahi program Exalter Students: Inkubasi, Mentorship, Kompetisi nasional & internasional, Konferensi, Summit, dan Komunitas untuk generasi inovatif Indonesia." />
    <meta property="og:image" content="https://www.exalterstudents.com/images/logo.jpeg" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="Exalter Students" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Program — Exalter Students | Inkubasi, Mentorship & Kompetisi" />
    <meta name="twitter:description" content="Jelajahi program Exalter Students: Inkubasi, Mentorship, Kompetisi, Konferensi, Summit, dan Komunitas." />
    <meta name="twitter:image" content="https://www.exalterstudents.com/images/logo.jpeg" />
  </head>
  <body>
    <Navigation client:load currentPath="/program" />
    <main>
      <ServiceFullSection
        title={content.serviceFull.title}
        subtitle={content.serviceFull.subtitle}
        cards={content.serviceFull.cards}
      />
      <MetricsSection metrics={content.metrics} />
    </main>
    <Footer />
    <ScrollToTop client:load />
  </body>
</html>
